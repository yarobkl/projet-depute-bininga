PassengerEnabled on
PassengerAppRoot "/home/wude3801/public_html"
PassengerBaseURI "/"
PassengerPython "/home/wude3801/virtualenv/bininga/3.10/bin/python"

DirectoryIndex index.html

<FilesMatch "(^\.|\.py$|\.pem$|\.db$|\.log$|\.pid$|^requirements\.txt$|^(users|sessions|contacts|crm|editorial|news_monitor|blocked_ips|attack_scores)\.json$)">
  Require all denied
</FilesMatch>

RewriteEngine On
RewriteRule (^|/)\.git(/|$) - [F,L]
RewriteCond %{THE_REQUEST} \s/+admin\.html[\s?] [NC]
RewriteRule ^admin\.html$ - [R=404,L]
RewriteRule ^espace-ministre-ab-2025/?$ admin.html [L]

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  <FilesMatch "\.(html|css|js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
