# Copier ce fichier vers .env sur o2switch, puis remplir les valeurs cPanel.
# Ne jamais committer le vrai .env.

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=cpaneluser_bininga
MYSQL_USER=cpaneluser_bininga
MYSQL_PASSWORD=mot_de_passe_mysql

# Admin
BININGA_USER=admin
BININGA_PASS=mot_de_passe_admin_fort
ADMIN_SECRET_PATH=espace-prive-bininga-long-secret
BININGA_PRODUCTION=1

# Optionnel : seulement pour restaurer volontairement data.json vers la base.
# Laisser vide ou 0 en production.
BININGA_FORCE_FILE_SYNC=0

# Optionnel mais recommandé en production réelle :
# si cette variable vaut 1, le site refuse de démarrer sans MySQL/PostgreSQL.
# BININGA_REQUIRE_DB=1
